# HerdHub Environment Configuration Template
# Copy this file to `.env` and fill in your actual values
# NEVER commit `.env` to version control - it contains secrets!

# Admin Authentication (required for server startup)
ADMIN_EMAIL=your_admin_email@example.com
ADMIN_PASS=your_admin_password_here

# Backup Script Configuration (optional, for scripts/backup-production.mjs)
BACKUP_USER=your_admin_email@example.com
BACKUP_PASS=your_admin_password_here
BASE_URL=https://herdhub-production-7da5.up.railway.app

# Data Directory Configuration
DATA_DIR=./data  # Local development (relative to server.js)
# DATA_DIR=/app/HerdHub/data  # Railway production

# Optional: Test Configuration
SEED_ADMIN_PASSWORD=admin123  # For test runner

# Optional: Development overrides
# PORT=5176  # Override default port
# NODE_ENV=development  # development | test | production

# ============================================
# INSTRUCTIONS:
# 1. Copy this file to `.env` in the same directory
# 2. Replace placeholder values with your actual credentials
# 3. For Railway production, set these as environment variables in Railway dashboard
# 4. NEVER commit `.env` to git - it's in .gitignore for security
# ============================================

# Required for:
# - Server startup (ADMIN_EMAIL, ADMIN_PASS, DATA_DIR)
# - Backup script (BACKUP_USER, BACKUP_PASS, BASE_URL)
# - Test runner (SEED_ADMIN_PASSWORD)
